generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatarUrl String?
  phone     String?
  events    Event[]

  @@index([email])
  @@map("users")
}

model EventType {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  icon        String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  events      Event[]
  templates   Template[]

  @@index([slug])
  @@map("event_types")
}

model Template {
  id          String    @id @default(cuid())
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  config      Json?
  eventTypeId String
  previewUrl  String?
  thumbnail   String?
  events      Event[]
  eventType   EventType @relation(fields: [eventTypeId], references: [id])

  @@index([eventTypeId])
  @@map("templates")
}

model Event {
  id                   String              @id @default(cuid())
  title                String
  date                 DateTime
  location             String
  description          String?
  coverImage           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  userId               String
  address              String?
  coordinates          Json?
  eventTypeId          String?
  googleMapLink        String?
  guestCount           Int                 @default(0)
  khqrDollar           String?
  khqrRiel             String?
  metadata             Json?
  musicUrl             String?
  slug                 String?             @unique
  templateId           String?
  type                 EventTypeEnum?
  event_gallery_images EventGalleryImage[]
  eventType            EventType?          @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  template             Template?           @relation(fields: [templateId], references: [id], onDelete: Restrict)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses             Expense[]
  gifts                Gift[]
  guests               Guest[]

  @@index([userId])
  @@index([eventTypeId])
  @@index([templateId])
  @@index([slug])
  @@index([date])
  @@map("events")
}

model EventGalleryImage {
  id            Int      @id @default(autoincrement())
  event_id      String
  image_url     String
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime
  events        Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([event_id, image_url])
  @@index([event_id])
  @@map("event_gallery_images")
}

model Guest {
  id              String            @id @default(cuid())
  name            String
  email           String?
  phone           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  eventId         String
  adultCount      Int               @default(0)
  childrenCount   Int               @default(0)
  greetingMessage String?
  group           String?           @default("GROOM_SIDE")
  note            String?
  rsvpStatus      RSVPStatus        @default(PENDING)
  tableNumber     String?
  tag             String?           @default("OTHERS")
  status          InvitationStatus?
  gifts           Gift[]
  event           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([rsvpStatus])
  @@index([phone])
  @@map("guests")
}

model Gift {
  id           String           @id @default(cuid())
  eventId      String
  guestId      String
  paymentType  GiftPaymentType
  currencyType GiftCurrencyType
  amount       Float
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest        Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([eventId, guestId])
  @@index([eventId])
  @@index([guestId])
  @@map("gifts")
}

model Expense {
  id        String           @id @default(cuid())
  eventId   String
  name      String
  budget    Float
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  payments  ExpensePayment[]
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("expenses")
}

model ExpensePayment {
  id          String   @id @default(cuid())
  expenseId   String
  description String
  amount      Float
  note        String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([paidAt])
  @@map("expense_payments")
}

enum UserRole {
  USER
  ADMIN
  CUSTOMER
}

enum EventTypeEnum {
  WEDDING
  BIRTHDAY
  HOUSEWARMING
  MEMORIAL
  ENGAGEMENT
  GRADUATION
  BABY_SHOWER
  OTHER
}

enum InvitationStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum GiftPaymentType {
  CASH
  KHQR
}

enum GiftCurrencyType {
  USD
  KHR
}
